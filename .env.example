# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际值

# =====================
# 数据库配置
# =====================
POSTGRES_USER=patent_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=patent_assist

# 数据库连接 URL（用于 Rust 后端）
DATABASE_URL=postgresql://patent_user:your-secure-password-here@localhost:5432/patent_assist

# =====================
# Redis 配置
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# =====================
# JWT 配置
# =====================
JWT_SECRET=your-jwt-secret-min-32-chars-change-this-in-production
JWT_EXPIRY_HOURS=24

# =====================
# AI API 配置
# =====================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =====================
# 服务器配置
# =====================
SERVER_PORT=3000
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50

# =====================
# 日志配置
# =====================
RUST_LOG=info,ai_patent_assist_backend=debug
