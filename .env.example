# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际值

# =====================
# 数据库配置
# =====================
POSTGRES_USER=patent_user
POSTGRES_PASSWORD=your-secure-password-here

# =====================
# Redis 配置
# =====================
REDIS_PASSWORD=your-redis-password-here

# =====================
# JWT 配置
# =====================
JWT_SECRET=your-jwt-secret-min-32-chars

# =====================
# AI API 配置
# =====================
ANTHROPIC_API_KEY=your-anthropic-api-key

# =====================
# 服务器配置
# =====================
SERVER_PORT=3000
JWT_EXPIRY_HOURS=24
