# 后端本地开发配置
# 复制 .env.example 并修改此文件

# 数据库连接
DATABASE_URL=postgresql://patent_user:password@localhost:5432/patent_assist

# Redis（可选）
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=dev-jwt-secret-key-for-local-development-only-min-32-chars

# AI API 配置
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 服务器配置
SERVER_PORT=3000
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50

# 日志
RUST_LOG=info,ai_patent_assist_backend=debug
